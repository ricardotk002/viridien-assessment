generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MenuItem {
  id    String  @id
  cat   String
  name  String
  price Float
  desc  String
  tags  String
  hue   Int
  sizes String?
  image String?
}

model Order {
  id        String   @id @default(cuid())
  items     String   // JSON: [{menuId, qty, price, notes}]
  total     Float
  status    String   @default("placed")
  createdAt DateTime @default(now())
}
